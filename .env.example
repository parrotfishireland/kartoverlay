# Copy to .env.local and fill in values

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Modal endpoint URL — get this after running: modal deploy kartoverlay-api/modal_app.py
# It will look like: https://your-username--kartoverlay-generate-video.modal.run
MODAL_ENDPOINT=https://YOUR-USERNAME--kartoverlay-generate-video.modal.run
